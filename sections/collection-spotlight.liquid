{% assign spotlight_collection = collections[section.settings.collection_handle] %}

<section
  id="home-featured-collection"
  class="collection-spotlight"
  data-section-id="{{ section.id }}"
  data-collection-handle="{{ section.settings.collection_handle }}"
  data-products-limit="{{ section.settings.products_limit }}"
>
  <div class="collection-spotlight__inner">
    <div class="collection-spotlight__header">
      {% if section.settings.eyebrow != blank %}
        <p class="collection-spotlight__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="collection-spotlight__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="collection-spotlight__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if spotlight_collection != blank and section.settings.button_label != blank %}
        <a class="collection-spotlight__button" href="{{ spotlight_collection.url }}">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="collection-spotlight__products" id="CollectionSpotlight-{{ section.id }}">
      {% if spotlight_collection != blank and spotlight_collection.products_count > 0 %}
        {% for product in spotlight_collection.products limit: section.settings.products_limit %}
          <a class="collection-spotlight__product-card" href="{{ product.url }}">
            <div class="collection-spotlight__product-image-wrap">
              {% if product.featured_image %}
                {{
                  product.featured_image
                  | image_url: width: 800
                  | image_tag: class: 'collection-spotlight__product-image', loading: 'lazy', alt: product.title
                }}
              {% else %}
                <div class="collection-spotlight__product-image collection-spotlight__product-image--empty">
                  No image
                </div>
              {% endif %}
            </div>
    
            <div class="collection-spotlight__product-content">
              <h3 class="collection-spotlight__product-title">{{ product.title }}</h3>
              <p class="collection-spotlight__product-price">{{ product.price | money }}</p>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="collection-spotlight__placeholder">
          No products found for this collection.
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .collection-spotlight {
    padding: 40px 20px 72px;
    background: linear-gradient(180deg, #f7f7fb 0%, #ffffff 100%);
  }

  .collection-spotlight__inner {
    width: var(--content-width);
    margin: 0 auto;
  }

  .collection-spotlight__header {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .collection-spotlight__eyebrow {
    margin: 0 0 10px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .collection-spotlight__title {
    margin: 0 0 12px;
    font-size: clamp(2.1rem, 4vw, 3rem);
    line-height: 1.05;
    color: #111827;
  }

  .collection-spotlight__subtitle {
    margin: 0;
    max-width: 62ch;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #4b5563;
  }

  .collection-spotlight__products {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .collection-spotlight__placeholder {
    grid-column: 1 / -1;
    padding: 24px;
    border: 1px dashed #c7cad1;
    background: #fff;
    color: #5c5f62;
    text-align: center;
  }

  .collection-spotlight__product-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #ffffff;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .collection-spotlight__product-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 48px rgba(15, 23, 42, 0.12);
  }

  .collection-spotlight__product-image-wrap {
    aspect-ratio: 1 / 1;
    background: #f2f3f5;
  }

  .collection-spotlight__product-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-spotlight__product-image--empty {
    display: grid;
    place-items: center;
    color: #5c5f62;
  }

  .collection-spotlight__product-content {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    justify-content: space-between;
    padding: 18px;
  }

  .collection-spotlight__product-title {
    margin: 0 0 8px;
    font-size: 1.05rem;
    line-height: 1.3;
    color: #111827;
  }

  .collection-spotlight__product-price {
    margin: 0;
    color: #4b5563;
    font-weight: 700;
  }

  .collection-spotlight__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 20px;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    background: #111827;
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .collection-spotlight__button:hover {
    background: #1f2937;
    transform: translateY(-1px);
  }

  @media (max-width: 990px) {
    .collection-spotlight__products {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 749px) {
    .collection-spotlight {
      padding: 48px 16px;
    }

    .collection-spotlight__title {
      font-size: 30px;
    }

    .collection-spotlight__products {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Spotlight",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JDM Legends"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A curated lineup of iconic Japanese cars selected for enthusiasts, collectors, and dream-garage builds."
    },
    {
      "type": "text",
      "id": "collection_handle",
      "label": "Collection handle",
      "default": "frontpage"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products limit"
    }
  ],
  "presets": [
    {
      "name": "Collection Spotlight"
    }
  ]
}
{% endschema %}