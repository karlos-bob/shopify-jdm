{% assign hero_collection = collections[section.settings.collection_handle] %}
{% assign hero_image = section.settings.background_image %}

{% if hero_image == blank and hero_collection != blank and hero_collection.featured_image %}
  {% assign hero_image = hero_collection.featured_image %}
{% endif %}

<section class="jdm-hero jdm-hero--{{ section.id }} full-width" data-parallax-speed="0.3">
  <div class="jdm-hero__background" aria-hidden="true">
    {% if hero_image != blank %}
      {{
        hero_image
        | image_url: width: 2400
        | image_tag: class: 'jdm-hero__background-media', loading: 'eager', alt: section.settings.heading
      }}
    {% else %}
      <div class="jdm-hero__background-media jdm-hero__background-media--placeholder">JDM Legends</div>
    {% endif %}
  </div>

  <div class="jdm-hero__overlay"></div>

  <div class="jdm-hero__shell">
    <div class="jdm-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="jdm-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="jdm-hero__title">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="jdm-hero__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="jdm-hero__actions">
        {% if hero_collection != blank and section.settings.primary_button_label != blank %}
          <a class="jdm-hero__button jdm-hero__button--primary" href="{{ hero_collection.url }}">
            {{ section.settings.primary_button_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_button_label != blank %}
          <a class="jdm-hero__button jdm-hero__button--secondary" href="#home-featured-collection">
            {{ section.settings.secondary_button_label }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="jdm-hero__stats">
      <div class="jdm-hero__stat">
        <span class="jdm-hero__stat-value">{{ hero_collection.products_count | default: 0 }}</span>
        <span class="jdm-hero__stat-label">Featured vehicles</span>
      </div>
      <div class="jdm-hero__stat">
        <span class="jdm-hero__stat-value">90s</span>
        <span class="jdm-hero__stat-label">JDM era focus</span>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.querySelector('.jdm-hero--{{ section.id }}');

    if (!section || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const media = section.querySelector('.jdm-hero__background-media');
    if (!media) return;

    let ticking = false;

    const updateParallax = () => {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;

      if (rect.bottom < 0 || rect.top > viewportHeight) {
        ticking = false;
        return;
      }

      const speed = Number(section.dataset.parallaxSpeed || 0.3);
      const offset = (viewportHeight / 2 - (rect.top + rect.height / 2)) * speed;
      media.style.transform = `translate3d(0, ${offset.toFixed(2)}px, 0) scale(1.14)`;
      ticking = false;
    };

    const requestUpdate = () => {
      if (window.innerWidth < 750) return;
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(updateParallax);
      }
    };

    requestUpdate();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
  })();
</script>

{% stylesheet %}
  .jdm-hero {
    position: relative;
    overflow: hidden;
    min-height: 78vh;
    padding: 56px 20px 48px;
    background: #0f172a;
    color: #ffffff;
  }

  .jdm-hero__background,
  .jdm-hero__overlay {
    position: absolute;
    inset: 0;
  }

  .jdm-hero__background {
    overflow: hidden;
  }

  .jdm-hero__background-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate3d(0, 0, 0) scale(1.14);
    will-change: transform;
  }

  .jdm-hero__background-media--placeholder {
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at top right, rgba(124, 58, 237, 0.3), transparent 32%),
      linear-gradient(135deg, #111827 0%, #1f2937 100%);
    color: #ffffff;
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .jdm-hero__overlay {
    background:
      linear-gradient(90deg, rgba(15, 23, 42, 0.84) 0%, rgba(15, 23, 42, 0.5) 42%, rgba(15, 23, 42, 0.2) 100%),
      linear-gradient(180deg, rgba(15, 23, 42, 0.12) 0%, rgba(15, 23, 42, 0.56) 100%);
  }

  .jdm-hero__shell {
    position: relative;
    z-index: 1;
    width: var(--content-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 40px;
    align-items: end;
    min-height: calc(78vh - 104px);
  }

  .jdm-hero__content,
  .jdm-hero__stats {
    min-width: 0;
  }

  .jdm-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    max-width: 760px;
    padding: 24px 0;
  }

  .jdm-hero__eyebrow {
    margin-bottom: 14px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .jdm-hero__title {
    margin-bottom: 18px;
    font-size: clamp(3rem, 6vw, 5.25rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: #ffffff;
  }

  .jdm-hero__subtitle {
    max-width: 60ch;
    margin-bottom: 28px;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .jdm-hero__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .jdm-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 20px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .jdm-hero__button--primary {
    background: #ffffff;
    color: #111827;
  }

  .jdm-hero__button--primary:hover {
    background: #f3f4f6;
    transform: translateY(-1px);
  }

  .jdm-hero__button--secondary {
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    backdrop-filter: blur(10px);
  }

  .jdm-hero__button--secondary:hover {
    background: rgba(255, 255, 255, 0.14);
    transform: translateY(-1px);
  }

  .jdm-hero__stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    align-self: end;
    padding-bottom: 12px;
  }

  .jdm-hero__stat {
    padding: 16px 18px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 20px;
    background: rgba(17, 24, 39, 0.22);
    backdrop-filter: blur(14px);
    color: #ffffff;
  }

  .jdm-hero__stat-value {
    display: block;
    margin-bottom: 4px;
    font-size: 1.4rem;
    font-weight: 700;
  }

  .jdm-hero__stat-label {
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.95rem;
  }

  @media (max-width: 989px) {
    .jdm-hero__shell {
      grid-template-columns: 1fr;
      gap: 24px;
      min-height: auto;
    }

    .jdm-hero {
      min-height: 640px;
      padding: 44px 20px 36px;
    }

    .jdm-hero__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: 480px;
    }
  }

  @media (max-width: 749px) {
    .jdm-hero {
      min-height: 540px;
      padding: 36px 16px 28px;
    }

    .jdm-hero__shell {
      gap: 18px;
    }

    .jdm-hero__title {
      font-size: clamp(2.6rem, 12vw, 4rem);
    }

    .jdm-hero__stats {
      grid-template-columns: 1fr;
    }

    .jdm-hero__background-media {
      transform: none !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "JDM Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curated import inventory"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JDM Legends"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A boutique storefront for iconic Japanese performance cars, featuring hand-picked legends from the golden era of drift, street, and collector culture."
    },
    {
      "type": "text",
      "id": "collection_handle",
      "label": "Collection handle",
      "default": "jdm-legends"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Shop collection"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "View featured cars"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "presets": [
    {
      "name": "JDM Hero"
    }
  ]
}
{% endschema %}
