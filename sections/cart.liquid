{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<section class="cart-page full-width">
  <div class="cart-page__inner">
    <div class="cart-page__header">
      <p class="cart-page__eyebrow">Your garage</p>
      <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>
      <p class="cart-page__subtitle">
        Review your selected vehicles and proceed to checkout when you're ready.
      </p>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" class="cart-page__layout">
        <div class="cart-page__items">
          {% for item in cart.items %}
            <article class="cart-page__item">
              <a class="cart-page__item-media" href="{{ item.url }}">
                {% if item.image %}
                  {{ item.image | image_url: width: 900 | image_tag: class: 'cart-page__item-image', loading: 'lazy', alt: item.product.title }}
                {% else %}
                  <div class="cart-page__item-image cart-page__item-image--empty">No image</div>
                {% endif %}
              </a>

              <div class="cart-page__item-content">
                <div class="cart-page__item-main">
                  <h2 class="cart-page__item-title">
                    <a href="{{ item.url }}">{{ item.product.title }}</a>
                  </h2>

                  {% unless item.product.has_only_default_variant %}
                    <p class="cart-page__item-variant">{{ item.variant.title }}</p>
                  {% endunless %}

                  <p class="cart-page__item-price">{{ item.final_line_price | money }}</p>
                </div>

                <div class="cart-page__item-actions">
                  <label class="cart-page__label" for="CartQuantity-{{ item.key }}">Quantity</label>
                  <div class="cart-page__quantity-row">
                    <input
                      id="CartQuantity-{{ item.key }}"
                      class="cart-page__quantity"
                      type="number"
                      name="updates[]"
                      min="0"
                      value="{{ item.quantity }}"
                    >
                    <button class="cart-page__update" type="submit" name="update">
                      {{ 'cart.update' | t }}
                    </button>
                  </div>

                  <a class="cart-page__remove" href="{{ item.url_to_remove }}">
                    {{ 'cart.remove' | t }}
                  </a>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>

        <aside class="cart-page__summary">
          <div class="cart-page__summary-card">
            <p class="cart-page__summary-label">Order summary</p>
            <div class="cart-page__summary-row">
              <span>Items</span>
              <span>{{ cart.item_count }}</span>
            </div>
            <div class="cart-page__summary-row cart-page__summary-row--total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <button class="cart-page__checkout" type="submit" name="checkout">
              {{ 'cart.checkout' | t }}
            </button>

            <a class="cart-page__continue" href="{{ routes.all_products_collection_url }}">
              Continue shopping
            </a>
          </div>
        </aside>
      </form>
    {% else %}
      <div class="cart-page__empty">
        <h2 class="cart-page__empty-title">Your cart is empty</h2>
        <p class="cart-page__empty-text">
          Explore the collection and add a few JDM legends to your garage.
        </p>
        <a class="cart-page__empty-link" href="{{ routes.all_products_collection_url }}">
          Browse vehicles
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .cart-page {
    padding: 40px 20px 72px;
    background: linear-gradient(180deg, #f7f7fb 0%, #ffffff 100%);
  }

  .cart-page__inner {
    width: min(1200px, 100%);
    margin: 0 auto;
  }

  .cart-page__header {
    margin-bottom: 28px;
  }

  .cart-page__eyebrow {
    margin-bottom: 8px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .cart-page__title {
    margin-bottom: 10px;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    color: #111827;
  }

  .cart-page__subtitle {
    color: #4b5563;
    max-width: 60ch;
    line-height: 1.65;
  }

  .cart-page__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 360px);
    gap: 28px;
    align-items: start;
  }

  .cart-page__items {
    display: grid;
    gap: 20px;
  }

  .cart-page__item,
  .cart-page__summary-card,
  .cart-page__empty {
    background: #ffffff;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  }

  .cart-page__item {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    overflow: hidden;
  }

  .cart-page__item-media {
    display: block;
    background: #f3f4f6;
  }

  .cart-page__item-image {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
  }

  .cart-page__item-image--empty {
    display: grid;
    place-items: center;
    color: #6b7280;
  }

  .cart-page__item-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 20px;
    padding: 24px;
    align-items: start;
  }

  .cart-page__item-title {
    margin-bottom: 8px;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  .cart-page__item-title a {
    color: #111827;
    text-decoration: none;
  }

  .cart-page__item-title a:hover {
    text-decoration: underline;
  }

  .cart-page__item-variant {
    margin-bottom: 8px;
    color: #6b7280;
  }

  .cart-page__item-price {
    color: #111827;
    font-weight: 700;
  }

  .cart-page__item-actions {
    min-width: 180px;
  }

  .cart-page__label {
    display: block;
    margin-bottom: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    color: #111827;
  }

  .cart-page__quantity-row {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .cart-page__quantity {
    width: 84px;
    min-height: 44px;
    padding: 0 12px;
    border: 1px solid #d1d5db;
    border-radius: 14px;
    background: #ffffff;
  }

  .cart-page__update,
  .cart-page__checkout,
  .cart-page__empty-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border: 0;
    border-radius: 999px;
    background: #111827;
    color: #ffffff;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .cart-page__update:hover,
  .cart-page__checkout:hover,
  .cart-page__empty-link:hover {
    background: #1f2937;
    transform: translateY(-1px);
  }

  .cart-page__remove {
    display: inline-block;
    margin-top: 14px;
    color: #b91c1c;
    text-decoration: none;
    font-weight: 600;
  }

  .cart-page__remove:hover {
    text-decoration: underline;
  }

  .cart-page__summary {
    position: sticky;
    top: 24px;
  }

  .cart-page__summary-card {
    padding: 24px;
  }

  .cart-page__summary-label {
    margin-bottom: 18px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .cart-page__summary-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    color: #4b5563;
    border-bottom: 1px solid #e5e7eb;
  }

  .cart-page__summary-row--total {
    margin-bottom: 20px;
    color: #111827;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .cart-page__checkout {
    width: 100%;
    margin-bottom: 12px;
  }

  .cart-page__continue {
    display: inline-flex;
    color: #4b5563;
    text-decoration: none;
    font-weight: 600;
  }

  .cart-page__continue:hover {
    text-decoration: underline;
  }

  .cart-page__empty {
    padding: 32px;
    text-align: center;
  }

  .cart-page__empty-title {
    margin-bottom: 10px;
    color: #111827;
  }

  .cart-page__empty-text {
    margin-bottom: 20px;
    color: #6b7280;
  }

  @media (max-width: 989px) {
    .cart-page__layout {
      grid-template-columns: 1fr;
    }

    .cart-page__summary {
      position: static;
    }

    .cart-page__item {
      grid-template-columns: 1fr;
    }

    .cart-page__item-content {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 749px) {
    .cart-page {
      padding: 32px 16px 56px;
    }

    .cart-page__quantity-row {
      flex-direction: column;
      align-items: stretch;
    }

    .cart-page__quantity,
    .cart-page__update {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
