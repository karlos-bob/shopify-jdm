{% assign footer_brand_name = section.settings.brand_name %}
{% if footer_brand_name == blank %}
  {% if shop.name == 'My Store' %}
    {% assign footer_brand_name = 'JDM Legends' %}
  {% else %}
    {% assign footer_brand_name = shop.name %}
  {% endif %}
{% endif %}
{% assign featured_collection_url = routes.collections_url | append: '/jdm-legends' %}

<footer class="site-footer">
  <div class="site-footer__grid">
    <div class="site-footer__column">
      <p class="site-footer__heading">{{ section.settings.quick_links_title }}</p>
      <div class="site-footer__links">
        {% if section.settings.menu != blank and section.settings.menu.links.size > 0 %}
          {% for link in section.settings.menu.links %}
            {{ link.title | link_to: link.url }}
          {% endfor %}
        {% else %}
          <a href="{{ routes.root_url }}">Home</a>
          <a href="{{ featured_collection_url }}">Collection</a>
          <a href="/pages/about">About</a>
          <a href="/pages/faq">FAQ</a>
        {% endif %}
      </div>
    </div>

    <div class="site-footer__column">
      <p class="site-footer__heading">{{ section.settings.info_links_title }}</p>
      <div class="site-footer__links">
        {% if section.settings.info_menu != blank and section.settings.info_menu.links.size > 0 %}
          {% for link in section.settings.info_menu.links %}
            {{ link.title | link_to: link.url }}
          {% endfor %}
        {% else %}
          <a href="/pages/about">About</a>
          <a href="/pages/faq">FAQ</a>
          <a href="{{ routes.cart_url }}">Cart</a>
          <a href="{{ featured_collection_url }}">Vehicles</a>
        {% endif %}
      </div>
    </div>

    <div class="site-footer__column site-footer__column--mission">
      <p class="site-footer__heading">{{ section.settings.mission_title }}</p>
      <p class="site-footer__mission">
        {{ section.settings.mission_text }}
      </p>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="site-footer__brand">
      <p class="site-footer__title">{{ footer_brand_name }}</p>
      <p class="site-footer__text">
        Boutique storefront concept built with Shopify Liquid, custom sections, and polished collection, product, and cart templates.
      </p>
    </div>

    <div class="site-footer__meta">
      <div class="site-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ footer_brand_name }}
      </div>

      {% if section.settings.show_payment_icons %}
        <div class="site-footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    margin-top: 0;
    padding: 20px 0 36px;
  }

  .site-footer a {
    text-decoration: none;
    color: #4b5563;
    width: fit-content;
  }

  .site-footer a:hover {
    color: #111827;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1.2fr;
    gap: 32px;
    padding-bottom: 24px;
  }

  .site-footer__column {
    display: grid;
    align-content: start;
    gap: 14px;
  }

  .site-footer__heading {
    font-weight: 700;
    color: #111827;
  }

  .site-footer__title {
    margin-bottom: 8px;
    font-weight: 700;
    color: #111827;
  }

  .site-footer__text {
    max-width: 46ch;
    color: #6b7280;
    line-height: 1.65;
  }

  .site-footer__mission {
    max-width: 34ch;
    color: #4b5563;
    line-height: 1.75;
  }

  .site-footer__links,
  .site-footer__payment {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .site-footer__bottom {
    display: grid;
    grid-template-columns: 1.4fr auto;
    gap: 24px;
    padding-top: 18px;
    border-top: 1px solid rgba(17, 24, 39, 0.08);
  }

  .site-footer__meta {
    display: grid;
    gap: 12px;
    justify-items: end;
  }

  .site-footer__copyright {
    color: #6b7280;
  }

  @media (max-width: 989px) {
    .site-footer__grid,
    .site-footer__bottom {
      grid-template-columns: 1fr;
    }

    .site-footer__meta {
      justify-items: start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "JDM Legends"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "quick_links_title",
      "label": "Quick links title",
      "default": "Quick links"
    },
    {
      "type": "link_list",
      "id": "info_menu",
      "label": "Info menu"
    },
    {
      "type": "text",
      "id": "info_links_title",
      "label": "Info links title",
      "default": "Info"
    },
    {
      "type": "text",
      "id": "mission_title",
      "label": "Mission title",
      "default": "Our mission"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission text",
      "default": "Curate iconic Japanese performance cars and present them in a cleaner, more premium storefront experience."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
