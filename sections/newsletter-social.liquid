<section class="newsletter-social full-width">
  <div class="newsletter-social__inner">
    <div class="newsletter-social__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="newsletter-social__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="newsletter-social__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="newsletter-social__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}

      {% form 'customer', class: 'newsletter-social__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">Email</label>
        <div class="newsletter-social__field">
          <input
            id="NewsletterEmail-{{ section.id }}"
            class="newsletter-social__input"
            type="email"
            name="contact[email]"
            value="{% if customer %}{{ customer.email }}{% endif %}"
            placeholder="{{ section.settings.email_placeholder }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
          >
          <button class="newsletter-social__submit" type="submit" aria-label="{{ section.settings.button_label }}">
            <span>{{ section.settings.button_label }}</span>
          </button>
        </div>
      {% endform %}
    </div>

    <div class="newsletter-social__socials">
      <div class="newsletter-social__social-list">
        {% if section.settings.facebook_url != blank %}
          <a class="newsletter-social__social-link" href="{{ section.settings.facebook_url }}" aria-label="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13.5 21v-7h2.4l.4-3h-2.8V9.2c0-.9.2-1.6 1.5-1.6H16V5.1c-.4-.1-1.3-.1-2.2-.1-2.2 0-3.8 1.3-3.8 3.9V11H7.5v3H10v7h3.5Z" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.instagram_url != blank %}
          <a class="newsletter-social__social-link" href="{{ section.settings.instagram_url }}" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7.5 3h9A4.5 4.5 0 0 1 21 7.5v9a4.5 4.5 0 0 1-4.5 4.5h-9A4.5 4.5 0 0 1 3 16.5v-9A4.5 4.5 0 0 1 7.5 3Zm0 1.8A2.7 2.7 0 0 0 4.8 7.5v9a2.7 2.7 0 0 0 2.7 2.7h9a2.7 2.7 0 0 0 2.7-2.7v-9a2.7 2.7 0 0 0-2.7-2.7h-9Zm9.5 1.3a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8A3.2 3.2 0 1 0 12 15.2 3.2 3.2 0 0 0 12 8.8Z" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.youtube_url != blank %}
          <a class="newsletter-social__social-link" href="{{ section.settings.youtube_url }}" aria-label="YouTube">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 8.4c-.2-1.3-1.2-2.3-2.5-2.5C16.7 5.6 12 5.6 12 5.6s-4.7 0-6.5.3C4.2 6.1 3.2 7.1 3 8.4c-.3 1.8-.3 3.6-.3 3.6s0 1.8.3 3.6c.2 1.3 1.2 2.3 2.5 2.5 1.8.3 6.5.3 6.5.3s4.7 0 6.5-.3c1.3-.2 2.3-1.2 2.5-2.5.3-1.8.3-3.6.3-3.6s0-1.8-.3-3.6ZM10.1 15.1V8.9l5.4 3.1-5.4 3.1Z" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.tiktok_url != blank %}
          <a class="newsletter-social__social-link" href="{{ section.settings.tiktok_url }}" aria-label="TikTok">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14.5 3c.4 1.9 1.5 3.3 3.4 3.8v2.6c-1.2 0-2.3-.3-3.4-.9v5.2a5 5 0 1 1-5-5c.3 0 .6 0 .9.1v2.7a2.4 2.4 0 1 0 1.5 2.2V3h2.6Z" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.x_url != blank %}
          <a class="newsletter-social__social-link" href="{{ section.settings.x_url }}" aria-label="X">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.9 4H21l-5.7 6.5L22 20h-5.2l-4.1-5.3L8 20H6l6-6.9L2 4h5.3l3.7 4.8L18.9 4Zm-1.8 14.5h1.5L6.6 5.4H5.1l12 13.1Z" fill="currentColor"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .newsletter-social {
    padding: 20px 20px 0;
  }

  .newsletter-social__inner {
    width: var(--content-width);
    margin: 0 auto;
    padding: 20px 0 24px;
    border-bottom: 1px solid rgba(17, 24, 39, 0.08);
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) auto;
    gap: 32px;
    align-items: end;
  }

  .newsletter-social__copy {
    min-width: 0;
  }

  .newsletter-social__eyebrow {
    margin: 0 0 10px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .newsletter-social__title {
    margin: 0 0 10px;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 1.05;
    color: #111827;
  }

  .newsletter-social__subtitle {
    margin: 0 0 18px;
    max-width: 62ch;
    color: #4b5563;
    line-height: 1.7;
  }

  .newsletter-social__form {
    max-width: 440px;
  }

  .newsletter-social__field {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
  }

  .newsletter-social__input {
    min-height: 50px;
    padding: 0 14px;
    border: 1px solid #d1d5db;
    background: #ffffff;
    color: #111827;
  }

  .newsletter-social__submit {
    min-width: 120px;
    min-height: 50px;
    padding: 0 18px;
    border: 0;
    border-radius: 999px;
    background: #111827;
    color: #ffffff;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .newsletter-social__submit:hover {
    background: #1f2937;
    transform: translateY(-1px);
  }

  .newsletter-social__socials {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .newsletter-social__social-list {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .newsletter-social__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #111827;
  }

  .newsletter-social__social-link svg {
    width: 1.25rem;
    height: 1.25rem;
    display: block;
  }

  .newsletter-social__social-link:hover {
    color: #7c3aed;
  }

  @media (max-width: 989px) {
    .newsletter-social__inner {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .newsletter-social__socials {
      justify-content: flex-start;
    }
  }

  @media (max-width: 749px) {
    .newsletter-social {
      padding: 16px 16px 0;
    }

    .newsletter-social__inner {
      padding: 16px 0 20px;
    }

    .newsletter-social__field {
      grid-template-columns: 1fr;
    }

    .newsletter-social__submit {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter & Social",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Stay updated"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe to new arrivals"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get notified when new collector cars, standout imports, and fresh storefront updates are added."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "x_url",
      "label": "X URL"
    }
  ],
  "presets": [
    {
      "name": "Newsletter & Social"
    }
  ]
}
{% endschema %}
